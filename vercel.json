{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/dist/index.html" },
    { "source": "/:path", "destination": "/dist/:path.html" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/dist/:path*", "destination": "/dist/:path*" }
  ]
}
