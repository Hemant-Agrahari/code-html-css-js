{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/dist/index.html" },
    { "source": "/:slug", "destination": "/dist/:slug.html" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/css/:path*", "destination": "/css/:path*" },
    { "source": "/js/:path*", "destination": "/js/:path*" }
  ]
}
